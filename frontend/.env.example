# AutoOps Dashboard Environment Variables
# In development: Vite proxy handles these (no config needed)
# In production (Docker): nginx handles proxying

VITE_APP_TITLE=AutoOps Platform
VITE_APP_VERSION=1.0.0

VITE_PROMETHEUS_URL=http://localhost:9090
VITE_HEALING_URL=http://localhost:8888
VITE_JENKINS_URL=http://localhost:8080
VITE_GRAFANA_URL=http://localhost:3001
VITE_ARGOCD_URL=http://localhost:8081
VITE_SONARQUBE_URL=http://localhost:9000
VITE_ALERTMANAGER_URL=http://localhost:9093
VITE_REGISTRY_UI_URL=http://localhost:8082

VITE_SIMULATION_MODE=false
VITE_SHOW_DEBUG=false
