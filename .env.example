# AutoOps local configuration

# API Gateway
PORT=3000
NODE_ENV=production
LOG_LEVEL=info
USER_SERVICE_URL=http://user-service:8000
METRICS_SERVICE_URL=http://metrics-collector:9091

# User Service
SERVICE_NAME=user-service
SERVICE_VERSION=1.0.0
USER_SERVICE_PORT=8000
MAX_USERS=1000

# Metrics Collector
VERSION=1.0.0
HTTP_PORT=9091
METRICS_PORT=9090
SCRAPE_INTERVAL_SECONDS=15

# AI healing service
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3-haiku
AI_ENABLED=true
ARGOCD_TOKEN=

# Infra credentials
GRAFANA_ADMIN_PASSWORD=autoops-grafana-2024
JENKINS_ADMIN_PASSWORD=autoops-admin-2024
SONAR_DB_PASSWORD=sonarpass
SONARQUBE_TOKEN=autoops-sonar-token
REGISTRY_USER=admin
REGISTRY_PASSWORD=autoops-registry-2024
GITLAB_WEBHOOK_SECRET=autoops-webhook-secret

# Optional monitoring config source. Leave unset for ./monitoring.
MONITORING_DIR=./monitoring

# Frontend quick links, embedded by Vite at image build time.
VITE_GRAFANA_URL=http://localhost:3001
VITE_JENKINS_URL=http://localhost:8080
VITE_ARGOCD_URL=http://localhost:8081
VITE_SONARQUBE_URL=http://localhost:9000
VITE_PROMETHEUS_URL=http://localhost:9090
VITE_ALERTMANAGER_URL=http://localhost:9093
VITE_REGISTRY_UI_URL=http://localhost:8082
