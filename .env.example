# AutoOps Platform - Phase 1 Environment Configuration
# Copy this file to .env and fill in values

# API Gateway
PORT=3000
NODE_ENV=production
LOG_LEVEL=info

# Service URLs (internal Docker network)
USER_SERVICE_URL=http://user-service:8000
METRICS_SERVICE_URL=http://metrics-collector:9091

# User Service
SERVICE_NAME=user-service
SERVICE_VERSION=1.0.0
USER_SERVICE_PORT=8000
MAX_USERS=1000

# Metrics Collector
VERSION=1.0.0
HTTP_PORT=9091
METRICS_PORT=9090
SCRAPE_INTERVAL_SECONDS=15

# ── Phase 5: Self-Healing Engine ──────────────────────────────
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ArgoCD token (get from ArgoCD UI → Settings → Accounts → Generate Token)
ARGOCD_TOKEN=your-argocd-token-here

# Set to false to use rule-based fallback only (no API key needed)
AI_ENABLED=true
